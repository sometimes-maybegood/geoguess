# Для локального запуска можно использовать следующие значения

# MongoDB connection string (для локального тестирования)
MONGODB=mongodb://localhost:27017/worldguessr

# Google OAuth credentials (замените на свои при необходимости)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# (Опционально) Maintenance secret
MAINTENANCE_SECRET=local_development_secret

# (Опционально) Maps.co API key
NEXT_PUBLIC_MAPSCO=

# (Опционально) OpenAI API key
OPENAI_API_KEY=